{
  "$meta": {
    "name": "Tactile Editorial",
    "direction": ["Tactile", "Realistic", "Messy", "Professional"],
    "base": { "spacingUnit": 4, "font": 16 }
  },
  "color": {
    "bg": {
      "base": "#f4f1ea",
      "raised": "#faf8f2",
      "sunken": "#ebe7dc",
      "inverse": "#1a1a1a"
    },
    "ink": {
      "strong": "#1a1a1a",
      "body": "#2b2926",
      "muted": "#6b6862",
      "faint": "#9c988e",
      "inverse": "#f4f1ea"
    },
    "accent": {
      "blue": "#1e3ae6",
      "red": "#ee3a20",
      "yellow": "#ffc61a",
      "green": "#1f7a4d",
      "blue-soft": "#d9defb",
      "red-soft": "#fbd9d2",
      "yellow-soft": "#fff0c2",
      "green-soft": "#d2ecdd"
    },
    "functional": {
      "danger": "#ee3a20",
      "warning": "#d98a00",
      "success": "#1f7a4d",
      "info": "#1e3ae6"
    },
    "border": {
      "strong": "#1a1a1a",
      "default": "#cfc9bc",
      "subtle": "#e2ddd1"
    }
  },
  "typography": {
    "family": {
      "sans": "\"Archivo\", \"Inter\", \"Helvetica Neue\", Arial, sans-serif",
      "heading": "\"Archivo\", \"Helvetica Neue\", Arial, sans-serif",
      "display": "\"Share Tech Mono\", \"Courier New\", ui-monospace, monospace",
      "mono": "\"Space Mono\", \"IBM Plex Mono\", ui-monospace, monospace"
    },
    "size": {
      "caption": "0.75rem",
      "body-sm": "0.8125rem",
      "body": "0.9375rem",
      "lead": "1.0625rem",
      "display-sm": "3rem",
      "display-md": "4.5rem",
      "display-lg": "6.5rem"
    },
    "weight": { "regular": 400, "medium": 500, "bold": 700, "heavy": 800, "black": 900 },
    "lineHeight": { "tight": 0.95, "snug": 1.2, "body": 1.5 },
    "letterSpacing": { "tight": "-0.02em", "normal": "0", "label": "0.08em" }
  },
  "spacing": {
    "0": "0",
    "1": "0.25rem",
    "2": "0.5rem",
    "3": "0.75rem",
    "4": "1rem",
    "6": "1.5rem",
    "8": "2rem",
    "12": "3rem",
    "16": "4rem",
    "24": "6rem",
    "32": "8rem"
  },
  "radius": { "none": "0", "sm": "2px", "pill": "999px" },
  "borderWidth": { "hairline": "1px", "default": "1.5px", "heavy": "2px" },
  "shadow": {
    "none": "none",
    "paper": "0 1px 2px rgba(26,22,18,0.06)",
    "raised": "0 2px 12px rgba(26,22,18,0.08)",
    "object": "0 8px 28px rgba(26,22,18,0.12)",
    "inset": "inset 0 1px 3px rgba(26,22,18,0.08)"
  },
  "motion": {
    "duration": {
      "instant": "80ms",
      "fast": "160ms",
      "base": "240ms",
      "slow": "400ms"
    },
    "easing": {
      "standard": "cubic-bezier(0.2, 0, 0, 1)",
      "entrance": "cubic-bezier(0.16, 1, 0.3, 1)",
      "exit": "cubic-bezier(0.4, 0, 1, 1)",
      "physical": "cubic-bezier(0.34, 1.56, 0.64, 1)"
    },
    "rotate": { "scrap-sm": "-1.5deg", "scrap-md": "2.5deg" }
  },
  "layout": {
    "container": { "max": "1200px", "narrow": "680px" },
    "grid": { "columns": 12, "gutter": "2rem" },
    "pagePadInline": { "base": "1.5rem", "md": "4rem", "lg": "6rem" },
    "breakpoint": { "sm": "480px", "md": "768px", "lg": "1024px", "xl": "1280px" }
  },
  "zIndex": {
    "base": 0,
    "raised": 10,
    "sticky": 100,
    "dropdown": 200,
    "scrim": 300,
    "modal": 310,
    "toast": 400
  },
  "opacity": { "disabled": 0.4, "scrim": 0.4 },
  "fluidType": {
    "display-sm": "clamp(2.25rem, 5vw, 3rem)",
    "display-md": "clamp(2.75rem, 8vw, 4.5rem)",
    "display-lg": "clamp(3.25rem, 11vw, 6.5rem)"
  }
}
